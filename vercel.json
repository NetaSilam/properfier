{
  "functions": {
    "api/main.py": {
      "runtime": "vercel-python@3.0.7"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/main.py" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist"
}